{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "strata",
  "version": "3.0.0",
  "identifier": "com.cntrvsy.strata",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "strata",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "visible": false,
        "devtools": false
      },
      {
        "label": "splashscreen",
        "title": "Strata Loading...",
        "url": "/splash.html",
        "width": 400,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": true,
        "resizable": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://cdn.crabnebula.app/update/frstudios/strata/{{target}}-{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwQjVGNzdGMEU3MTExOTYKUldTV0VYRU9mL2Uxc09TNFBRTFVBcDk0R04vR0I2Q2NNS2FlZGg0cnZOMUVVODV4WHJMZ1JtWHoK"
    }
  }
}
